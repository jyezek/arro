{
  "expo": {
    "name": "Arro",
    "slug": "arro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "arro",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0D0B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.arro",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Arro uses your microphone for practice interview sessions.",
        "NSSpeechRecognitionUsageDescription": "Arro uses speech recognition to transcribe your practice interview answers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#E8650A"
      },
      "package": "app.arro",
      "permissions": ["RECORD_AUDIO"],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser",
      ["expo-av", { "microphonePermission": "Arro uses your microphone for practice interview sessions." }],
      ["expo-document-picker", {}]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
